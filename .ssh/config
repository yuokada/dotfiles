# ForwardAgent yes
# UseKeychain yes

Host *
  ControlMaster auto
  ControlPath ~/.ssh/master-%r@%h:%p
  ServerAliveInterval 60
  ForwardAgent yes
  UseKeychain yes
  AddKeysToAgent yes

Host bms
        Hostname b-ms.info
        port 22
        IdentityFile ~/.ssh/bms/id_rsa
        User yuokada
Host github.com
        IdentityFile ~/.ssh/vps/id_rsa
        User yuokada
Host gist.github.com
        IdentityFile ~/.ssh/vps/id_rsa
        User yuokada
Host pypi.pyhton.org
        IdentityFile ~/.ssh/vps/id_rsa
        User yuokada
